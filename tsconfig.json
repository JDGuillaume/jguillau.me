{
  "extends": "astro/tsconfigs/strictest",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@css/*": ["./src/css/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@schemas/*": ["./src/schemas/*"]
    },
    "types": ["vitest/globals"]
  }
}
